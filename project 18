#include <stdio.h>

int main() {
    int num, i;

    // Prompt the user to enter a positive integer
    printf("Enter a positive integer: ");
    scanf("%d", &num);

    // Validate the input to ensure it is a positive integer
    if (num <= 0) {
        printf("Error: Please enter a number greater than 0.\n");
        return 1; 
    }

    printf("Factors of %d are: ", num);

    // Loop through all numbers from 1 up to the entered number
    for (i = 1; i <= num; ++i) {
        // If the remainder is 0, then i is a factor
if (num % i == 0) {
            printf("%d ", i);
        }
    }

    printf("\n");
    return 0;
}