#include <stdio.h>
#include <string.h>
#include <stdlib.h>

// Helper function to remove trailing newline character left by fgets
void remove_newline(char *str) {
    size_t len = strlen(str);
    if (len > 0 && str[len - 1] == '\n') {
        str[len - 1] = '\0';
    }
}

int main() {
    char str1[100], str2[100];
    int choice;

    while (1) {
        // Display Menu
        printf("\n=============================\n");
        printf("   STRING OPERATIONS MENU\n");
        printf("=============================\n");
         printf("1. Find Length of String\n");
        printf("2. Copy String\n");
        printf("3. Concatenate Strings\n");
        printf("4. Compare Strings\n");
        printf("5. Reverse String\n");
        printf("6. Exit\n");
        printf("Enter your choice (1-6): ");
        
        if (scanf("%d", &choice) != 1) {
            printf("Invalid input! Please enter a number.\n");
            exit(1); 
        }
        
        // Consume the leftover newline character from the input buffer
        getchar(); 

        switch (choice) {
            case 1:
                printf("Enter a string: ");
                 fgets(str1, sizeof(str1), stdin);
                remove_newline(str1);
                
                printf("Length of the string: %lu\n", strlen(str1));
                break;

            case 2:
                printf("Enter source string: ");
                fgets(str1, sizeof(str1), stdin);
                remove_newline(str1);
                
                strcpy(str2, str1);
                printf("Successfully copied! Target string: %s\n", str2);
                break;

            case 3:
                printf("Enter first string: ");
                fgets(str1, sizeof(str1), stdin);
                remove_newline(str1);
                
                printf("Enter second string to append: ");
                fgets(str2, sizeof(str2), stdin);
                remove_newline(str2);
                 // Prevent buffer overflow by checking combined size
                if (strlen(str1) + strlen(str2) < sizeof(str1)) {
                    strcat(str1, str2);
                    printf("Concatenated string: %s\n", str1);
                } else {
                    printf("Error: Combined string exceeds destination array limits.\n");
                }
                break;

            case 4:
                printf("Enter first string: ");
                fgets(str1, sizeof(str1), stdin);
                remove_newline(str1);
                
                printf("Enter second string: ");
                fgets(str2, sizeof(str2), stdin);
                remove_newline(str2);
                
                int cmp = strcmp(str1, str2);
                if (cmp == 0) {
                    printf("Strings are perfectly identical.\n");
                } else if (cmp > 0) {
                     printf("First string is lexicographically larger.\n");
                } else {
                    printf("Second string is lexicographically larger.\n");
                }
                break;

            case 5:
                printf("Enter a string to reverse: ");
                fgets(str1, sizeof(str1), stdin);
                remove_newline(str1);
                
                int len = strlen(str1);
                printf("Reversed string: ");
                for (int i = len - 1; i >= 0; i--) {
                    putchar(str1[i]);
                }
                printf("\n");
                break;

            case 6:
                printf("Exiting program. Goodbye!\n");
                exit(0);
 default:
                printf("Invalid choice! Please select an option between 1 and 6.\n");
        }
    }
    return 0;
}