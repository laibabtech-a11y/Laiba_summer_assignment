#include <stdio.h>

int main() {
    int num, originalNum, rem, sum = 0;
    long fact;

    // Take input from the user
    printf("Enter a number: ");
    scanf("%d", &num);

    // Copy the original number to a temporary variable
    originalNum = num;

    // Process each digit of the number
    while (num > 0) {
        // Step 1: Get the last digit
        rem = num % 10; 

        // Step 2: Calculate the factorial of the digit
        fact = 1;
        for (int i = 1; i <= rem; i++) {
            fact *= i;
        }

        // Step 3: Add the factorial to the sum
        sum += fact; 

        // Step 4: Remove the last digit from the number
        num /= 10; 
    }

    // Step 5: Check if the sum matches the original number
    if (sum == originalNum) {
        printf("%d is a Strong Number.\n", originalNum);
    } else {
        printf("%d is not a Strong Number.\n", originalNum);
    }
    return 0;
}