#include <stdio.h>

// Function to calculate x^n without using pow()
double calculate_power(double base, int exponent) {
    double result = 1.0;
    int abs_exponent = exponent;

    // Handle negative exponents by working with absolute value
    if (exponent < 0) {
        abs_exponent = -exponent;
    }

    // Multiply the base by itself 'abs_exponent' times
    for (int i = 0; i < abs_exponent; i++) {
        result *= base;
    }

    // If the original exponent was negative, invert the result
    if (exponent < 0) {
         return 1.0 / result;
    }

    return result;
}

int main() {
    double base;
    int exponent;

    // Prompt user for input
    printf("Enter base (x): ");
    if (scanf("%lf", &base) != 1) {
        printf("Invalid base input.\n");
        return 1;
    }

    printf("Enter integer exponent (n): ");
    if (scanf("%d", &exponent) != 1) {
        printf("Invalid exponent input.\n");
        return 1;
    }
     // Check for undefined mathematical condition (0^0 or 0 raised to negative power)
    if (base == 0.0 && exponent <= 0) {
        printf("Error: Undefined mathematical result (0 raised to a non-positive power).\n");
        return 1;
    }

    // Calculate result
    double answer = calculate_power(base, exponent);

    // Display result
    printf("%.2f raised to the power of %d is: %.6f\n", base, exponent, answer);

    return 0;
}