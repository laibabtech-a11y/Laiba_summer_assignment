#include <stdio.h>

int main() {
    char str[100];
    int length = 0;

    // Read string input from the user (handles spaces safely)
    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);

    // Loop through each character until the null terminator '\0' is found
    while (str[length] != '\0') {
        length++;
    }

    // fgets() includes the newline character '\n' in the buffer.
    // If present, we remove it from the total length count.
    if (length > 0 && str[length - 1] == '\n') {
        length--;
    }// Print the final string length
    printf("The length of the string is: %d\n", length);

    return 0;
}