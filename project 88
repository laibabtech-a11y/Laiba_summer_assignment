#include <stdio.h>
#include <ctype.h> // Required for isspace()

int count_words(const char *str) {
    int count = 0;
    int in_word = 0; // State flag: 1 means inside a word, 0 means outside

    for (int i = 0; str[i] != '\0'; i++) {
        // isspace() checks for spaces, tabs ('\t'), and newlines ('\n')
        if (isspace((unsigned char)str[i])) {
            in_word = 0; // We hit a space, so we are no longer inside a word
        } 
        // If it's a non-space character and we weren't already in a word
        else if (in_word == 0) {
            in_word = 1; // Mark that we entered a new word
            count++;     // Increment the word counter
        }
    }

    return count;
}

int main() {
    char sentence[200];

    printf("Enter a sentence: ");
    // fgets safely reads the entire line, including spaces
    if (fgets(sentence, sizeof(sentence), stdin) != NULL) {
        int words = count_words(sentence);
        printf("Total number of words: %d\n", words);
    }

    return 0;
}