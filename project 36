#include <stdio.h>

int main() {
    int rows = 5; // Total number of rows for the pyramid

    // Outer loop handles the number of rows
    for (int i = 1; i <= rows; i++) {
        
        // Inner loop 1: Prints the leading spaces for center alignment
        for (int j = 1; j <= rows - i; j++) {
            printf(" ");
        }

        // Inner loop 2: Prints the odd number of stars (2*i - 1)
        for (int k = 1; k <= (2 * i - 1); k++) {
            printf("*");
        }

        // Moves the cursor to the next line after finishing a row
        printf("\n");
    }

    return 0;
}
