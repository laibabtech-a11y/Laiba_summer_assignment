#include <stdio.h>
#include <string.h>

#define MAX_SIZE 1000 // Maximum string size
#define TOTAL_CHARS 256 // Total possible ASCII characters

int main() {
    char str[MAX_SIZE];
    int freq[TOTAL_CHARS] = {0}; // Initialize all frequencies to 0
    int i, max_index;

    printf("Enter any string: ");
    // Safely read string including spaces
    if (fgets(str, sizeof(str), stdin) == NULL) {
        printf("Error reading input.\n");
        return 1;
    }

    // Step 1: Count the frequency of each character
    for (i = 0; str[i] != '\0'; i++) {
        // Skip the newline character added by fgets
        if (str[i] == '\n') {
            continue;
        }
        
        // Use the character's ASCII value as the array index
        int ascii = (unsigned char)str[i];
        freq[ascii]++;
    }

    // Step 2: Find the character with the maximum frequency
    max_index = 0;
    for (i = 0; i < TOTAL_CHARS; i++) {
        // If current character has a higher frequency, update max_index
        if (freq[i] > freq[max_index]) {
            max_index = i;
        }   // Step 3: Print the result
    if (freq[max_index] > 0) {
        printf("Maximum occurring character is '%c' = %d times.\n", max_index, freq[max_index]);
    } else {
        printf("The string is empty.\n");
    }

    return 0;
}
    }
