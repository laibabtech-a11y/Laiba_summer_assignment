#include <stdio.h>

int main() {
    int arr1[100], arr2[100], intersection[100];
    int size1, size2, i, j, k;
    int isDuplicate, isPresentInArr2;

    // Input elements for the first array
    printf("Enter the size of the first array: ");
    scanf("%d", &size1);
    printf("Enter elements of the first array: \n");
    for (i = 0; i < size1; i++) {
        scanf("%d", &arr1[i]);
    }

    // Input elements for the second array
    printf("Enter the size of the second array: ");
    scanf("%d", &size2);
    printf("Enter elements of the second array: \n");
    for (i = 0; i < size2; i++) {
        scanf("%d", &arr2[i]);
    }
     k = 0; // Index for the intersection array

    // Find the intersection
    for (i = 0; i < size1; i++) {
        // Step 1: Check if the element is already processed to avoid duplicates
        isDuplicate = 0;
        for (int m = 0; m < k; m++) {
            if (arr1[i] == intersection[m]) {
                isDuplicate = 1;
                break;
            }
        }

        // Step 2: If it's not a duplicate, check if it exists in the second array
        if (!isDuplicate) {
            isPresentInArr2 = 0;
            for (j = 0; j < size2; j++) {
                if (arr1[i] == arr2[j]) {
                    isPresentInArr2 = 1;
                    break;
                }
            }
             // Step 3: If present in both, add to the intersection array
            if (isPresentInArr2) {
                intersection[k] = arr1[i];
                k++;
            }
        }
    }

    // Print the final result
    if (k > 0) {
        printf("\nIntersection of the two arrays: ");
        for (i = 0; i < k; i++) {
            printf("%d ", intersection[i]);
        }
        printf("\n");
    } else {
        printf("\nNo intersection found (no common elements).\n");
    }

    return 0;
}