#include <stdio.h>

// Function to find and print the first pair with the given target sum
void findPairBruteForce(int arr[], int size, int targetSum) {
    // Outer loop selects the first element
    for (int i = 0; i < size - 1; i++) {
        // Inner loop selects the second element
        for (int j = i + 1; j < size; j++) {
            if (arr[i] + arr[j] == targetSum) {
                printf("Pair found: (%d, %d)\n", arr[i], arr[j]);
                return; // Exit after finding the first matching pair
            }
        }
    }
    printf("No pair found with the given sum.\n");
}

int main() {
    int arr[] = {8, 7, 2, 5, 3, 1};
    int targetSum = 10;
    int size = sizeof(arr) / sizeof(arr[0]);
 findPairBruteForce(arr, size, targetSum);

    return 0;
}