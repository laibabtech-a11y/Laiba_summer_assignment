#include <stdio.h>

int main() {
    int rows = 5; // Total number of lines to print

    for (int i = 1; i <= rows; i++) {
        // 1. Print leading spaces for pyramid alignment
        for (int space = 1; space <= rows - i; space++) {
            printf(" ");
        }

        // 2. Print characters in increasing order (e.g., A, AB, ABC)
        char ch = 'A';
        for (int j = 1; j <= i; j++) {
            printf("%c", ch);
            ch++;
        }// 3. Print characters in decreasing order (e.g., BA, CBA)
        ch -= 2; // Step back to the character right before the peak
        for (int j = 1; j < i; j++) {
            printf("%c", ch);
            ch--;
        }

        // Move to the next line
        printf("\n");
    }

    return 0;
}
