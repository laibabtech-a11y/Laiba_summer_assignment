#include <stdio.h>

// Function to calculate the power of a number using integer math
int power(int base, int exp) {
    int res = 1;
    for (int i = 0; i < exp; i++) {
        res *= base;
    }
    return res;
}

int main() {
    int num, originalNum, remainder, digits = 0, sum = 0;

    // Prompt the user for input
    printf("Enter an integer: ");
    scanf("%d", &num);

    originalNum = num;

    // Step 1: Count the total number of digits
    while (originalNum != 0) {
        originalNum /= 10;
        digits++;
    }

    originalNum = num;

    // Step 2: Calculate the sum of the digits raised to the power of total digits
    while (originalNum != 0) {
        remainder = originalNum % 10;
        sum += power(remainder, digits);
        originalNum /= 10;
    }

    // Step 3: Check if the sum matches the original number
    if (sum == num) {
        printf("%d is an Armstrong number.\n", num);
    } else {
        printf("%d is not an Armstrong number.\n", num);
    }

    return 0;
}