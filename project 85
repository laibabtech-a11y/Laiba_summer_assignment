#include <stdio.h>
#include <ctype.h>

int main() {
    char str[200];
    int vowels = 0;
    int consonants = 0;

    printf("Enter a string: ");
    // Safely read a line of text including spaces
    fgets(str, sizeof(str), stdin);

    // Loop through each character until the null terminator '\0'
    for (int i = 0; str[i] != '\0'; i++) {
        char ch = str[i];

        // Check if the character is an alphabet letter
        if (isalpha(ch)) {
            // Convert to lowercase to make vowel checking easier
            ch = tolower(ch);
 // Check if the lowercase character is a vowel
            if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u') {
                vowels++;
            } else {
                // If it is an alphabet letter but not a vowel, it must be a consonant
                consonants++;
            }
        }
    }

    // Print the final counts
    printf("Total Vowels: %d\n", vowels);
    printf("Total Consonants: %d\n", consonants);

    return 0;
}