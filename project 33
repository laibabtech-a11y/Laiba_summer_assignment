#include <stdio.h>

int main() {
    int i, j, rows = 5;

    // Outer loop for the number of rows
    for (i = rows; i >= 1; i--) {
        // Inner loop to print numbers from 1 to i
        for (j = 1; j <= i; j++) {
            printf("%d", j);
        }
        // Move to the next line after each row
        printf("\n");
    }

    return 0;
}
