#include <stdio.h>

int main() {
    int i, j;
    int rows = 5;

    // Outer loop for the number of rows
    for (i = 1; i <= rows; i++) {
        // Inner loop to print characters from 'A' up to the current row number
        for (j = 1; j <= i; j++) {
            printf("%c", 'A' + j - 1);
        }
        // Move to the next line after printing each row
        printf("\n");
    }

    return 0;
}
