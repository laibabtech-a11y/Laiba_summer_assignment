#include <stdio.h>
#include <string.h>

#define MAX_NAMES 100
#define MAX_LENGTH 50

int main() {
    char names[MAX_NAMES][MAX_LENGTH];
    char temp[MAX_LENGTH];
    int n, i, j;

    // Ask user for the number of names
    printf("Enter the number of names: ");
    if (scanf("%d", &n) != 1 || n <= 0 || n > MAX_NAMES) {
        printf("Invalid number of names.\n");
        return 1;
    }
  // Consume the trailing newline character left by scanf
    getchar(); 

    // Input names from user
    printf("Enter %d names:\n", n);
    for (i = 0; i < n; i++) {
        // Read string including spaces safely, then remove trailing newline
        if (fgets(names[i], sizeof(names[i]), stdin)) {
            names[i][strcspn(names[i], "\n")] = '\0';
        }
    }

    // Bubble Sort Algorithm to sort names alphabetically
    for (i = 0; i < n - 1; i++) {
        for (j = 0; j < n - i - 1; j++) {
            // strcmp returns > 0 if names[j] is alphabetically greater than names[j+1]
            if (strcmp(names[j], names[j + 1]) > 0) {
                // Swap the two names using strcpy
                strcpy(temp, names[j]);
                  strcpy(names[j], names[j + 1]);
                strcpy(names[j + 1], temp);
            }
        }
    }

    // Display the sorted names
    printf("\nNames in alphabetical order:\n");
    for (i = 0; i < n; i++) {
        printf("%s\n", names[i]);
    }

    return 0;
}