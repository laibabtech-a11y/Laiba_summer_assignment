
#include <stdio.h>

int main() {
    int rows = 5;

    // Outer loop handles the number of rows
    for (int i = rows; i >= 1; i--) {
        
        // Inner loop handles the number of stars in each row
        for (int j = 1; j <= i; j++) {
            printf("*");
        }
        
        // Move to the next line after printing all stars in a row
        printf("\n");
    }

    return 0;
}