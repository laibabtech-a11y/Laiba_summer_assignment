#include <stdio.h>

int main() {
    int size = 5;

    // Outer loop handles the rows
    for (int i = 1; i <= size; i++) {
        // Inner loop handles the columns
        for (int j = 1; j <= size; j++) {
            // Print asterisk for the boundary (first/last row or column)
            if (i == 1 || i == size || j == 1 || j == size) {
                printf("*");
            } else {
                // Print space for the hollow interior
                printf(" ");
            }
        }
        // Move cursor to the next line after finishing each row
        printf("\n");
    }
    return 0;
}