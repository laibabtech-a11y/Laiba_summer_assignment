#include <stdio.h>

int main() {
    int decimal, i = 0;
    int binary[32]; // Array to store up to 32 bits

    // Prompt user for input
    printf("Enter a decimal number: ");
    if (scanf("%d", &decimal) != 1) {
        printf("Invalid input.\n");
        return 1;
    }

    // Edge case for zero
    if (decimal == 0) {
        printf("Binary equivalent: 0\n");
        return 0;
    }
     // Convert decimal to binary
    while (decimal > 0) {
        binary[i] = decimal % 2; // Store remainder (0 or 1)
        decimal = decimal / 2;   // Divide number by 2
        i++;
    }

    // Print the binary array in reverse order
    printf("Binary equivalent: ");
    for (int j = i - 1; j >= 0; j--) {
        printf("%d", binary[j]);
    }
    printf("\n");

    return 0;
}