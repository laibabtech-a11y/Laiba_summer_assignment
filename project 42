#include <stdio.h>

// Function declaration
int find_max(int num1, int num2);

int main() {
    int a, b, max_val;

    // User input
    printf("Enter two integers: ");
    scanf("%d %d", &a, &b);

    // Function call
    max_val = find_max(a, b);

    // Print result
    printf("The maximum number is: %d\n", max_val);

    return 0;
}
// Function definition to find the maximum
int find_max(int num1, int num2) {
    if (num1 > num2) {
        return num1;
    } else {
        return num2;
    }
}