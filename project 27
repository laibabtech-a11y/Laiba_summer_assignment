#include <stdio.h>

// Recursive function to reverse the digits of a number
int reverse_recursive(int num, int reversed_accumulator) {
    // Base case: when the remaining number becomes 0
    if (num == 0) {
        return reversed_accumulator;
    }
    
    // Extract the last digit and append it to the accumulated result
    int last_digit = num % 10;
    reversed_accumulator = (reversed_accumulator * 10) + last_digit;
    
    // Recursive call with the remaining digits
    return reverse_recursive(num / 10, reversed_accumulator);
}

int main() {
    int number;
     // Get input from the user
    printf("Enter an integer: ");
    if (scanf("%d", &number) != 1) {
        printf("Invalid input.\n");
        return 1;
    }

    // Handle negative numbers by preserving the sign
    int sign = (number < 0) ? -1 : 1;
    int absolute_number = (number < 0) ? -number : number;

    // Call the recursive function starting with 0 as the accumulator
    int result = reverse_recursive(absolute_number, 0) * sign;

    // Output the final result
    printf("Reversed number: %d\n", result);

    return 0;
}