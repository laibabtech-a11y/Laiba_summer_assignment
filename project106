#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

#define TOTAL_QUESTIONS 3

// Define a structure to hold quiz data safely
typedef struct {
    char question[256];
    char options[4][64];
    char correct_option;
} QuizQuestion;

// Function declarations
void runQuiz(QuizQuestion quiz[]);
void clearBuffer();

int main() {
    // Initialize the quiz array with questions, choices, and correct keys
    QuizQuestion quiz[TOTAL_QUESTIONS] = {
        {
 "Which programming language is known as the mother of all languages?",
            {"A. Python", "B. C", "C. Java", "D. C++"},
            'B'
        },
        {
            "What is the correct format specifier for printing an integer in C?",
            {"A. %f", "B. %c", "C. %d", "D. %s"},
            'C'
        },
        {
            "Which of the following is not a valid loop structure in C?",
            {"A. for", "B. while", "C. do-while", "D. repeat-until"},
            'D'
        }
    };
 printf("=========================================\n");
    printf("     WELCOME TO THE C PROGRAMMING QUIZ    \n");
    printf("=========================================\n\n");
    printf("Instructions: Enter A, B, C, or D for each question.\n\n");

    // Execute the main game loop
    runQuiz(quiz);

    return 0;
}

// Function to loop through questions, get input, and evaluate scores
void runQuiz(QuizQuestion quiz[]) {
    int score = 0;
    char user_guess;

    for (int i = 0; i < TOTAL_QUESTIONS; i++) {
        printf("-----------------------------------------\n");
        printf("Question %d: %s\n", i + 1, quiz[i].question);
        // Print out all four choices
        for (int j = 0; j < 4; j++) {
            printf("%s\n", quiz[i].options[j]);
        }

        // Handle and validate user input
        while (1) {
            printf("Your Answer: ");
            scanf(" %c", &user_guess); // Note the space before %c to consume whitespace
            clearBuffer();             // Flush trailing extra characters

            user_guess = toupper(user_guess); // Convert to uppercase for flexible input

            if (user_guess >= 'A' && user_guess <= 'D') {
                break; // Valid option selected
            }
            printf("Invalid selection! Please enter A, B, C, or D.\n");
        }
           // Evaluate user's selection
        if (user_guess == quiz[i].correct_option) {
            printf("\n✅ Correct!\n");
            score++;
        } else {
            printf("\n❌ Wrong! The correct answer was %c.\n", quiz[i].correct_option);
        }
        printf("-----------------------------------------\n\n");
    }

    // Display total final results
    printf("=========================================\n");
    printf("QUIZ FINISHED! Your final score: %d/%d\n", score, TOTAL_QUESTIONS);
    printf("Percentage: %.2f%%\n", ((float)score / TOTAL_QUESTIONS) * 100);
    printf("=========================================\n");
}
// Utility function to clear the standard input buffer stream
void clearBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}