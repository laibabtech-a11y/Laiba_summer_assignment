#include <stdio.h>

// Function to count the number of set bits
int countSetBits(unsigned int n) {
    int count = 0;
    
    // Loop runs only as many times as there are set bits
    while (n > 0) {
        n &= (n - 1); // Clears the lowest set bit
        count++;      // Increment the count of set bits
    }
    
    return count;
}

