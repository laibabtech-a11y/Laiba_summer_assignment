#include <stdio.h>

int main() {
    int arr[] = {4, 2, 8, 4, 2, 4, 9, 4, 1, 2};
    int n = sizeof(arr) / sizeof(arr[0]);
    
    int max_element = arr[0];
    int max_count = 0;
    
    // Outer loop to select each element
    for (int i = 0; i < n; i++) {
        int count = 0;
        
        // Inner loop to count occurrences of the selected element
        for (int j = 0; j < n; j++) {
            if (arr[j] == arr[i]) {
                count++;
                }
        }
        
        // Update maximum frequency and element if a higher count is found
        if (count > max_count) {
            max_count = count;
            max_element = arr[i];
        }
    }
    
    // Display the final result
    printf("Element with maximum frequency: %d\n", max_element);
    printf("Occurrences: %d times\n", max_count);
    
    return 0;
}