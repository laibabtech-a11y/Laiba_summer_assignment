#include <stdio.h>
#include <string.h>

void compressString(const char *input, char *output) {
    int i = 0;
    int j = 0; // Index for output string
    int len = strlen(input);

    while (i < len) {
        int count = 1;
        
        // Count consecutive occurrences of the current character
        while (i + 1 < len && input[i] == input[i + 1]) {
            count++;
            i++;
        }

        // Append the character to the output
        output[j++] = input[i];

        // Convert the integer count to characters and append to output
        int charsWritten = sprintf(&output[j], "%d", count);
        j += charsWritten;

        i++;
    }
    
    // Null-terminate the compressed string
    output[j] = '\0';
}

int main() {
    char inputString[100];
    char compressedString[200]; // Allocation size handles cases where counts add length

    printf("Enter a string to compress: ");
    if (scanf("%99s", inputString) == 1) {
        compressString(inputString, compressedString);
        
        printf("Original String:   %s\n", inputString);
        printf("Compressed String: %s\n", compressedString);
    }

    return 0;
}