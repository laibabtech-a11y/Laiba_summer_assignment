#include <stdio.h>

// Function to move all zeroes to the end of the array
void moveZeroesToEnd(int arr[], int n) {
    int count = 0; // Tracks the position for the next non-zero element

    // Step 1: Travel through the array. 
    // If the element is non-zero, shift it to the front.
    for (int i = 0; i < n; i++) {
        if (arr[i] != 0) {
            arr[count++] = arr[i];
        }
    }

    // Step 2: Fill the remaining indices with zeroes.
    while (count < n) {
        arr[count++] = 0;
    }
}
// Helper function to print the array
void printArray(int arr[], int n) {
    for (int i = 0; i < n; i++) {
        printf("%d ", arr[i]);
    }
    printf("\n");
}

int main() {
    int arr[] = {1, 2, 0, 4, 3, 0, 5, 0};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("Original array: ");
    printArray(arr, n);

    moveZeroesToEnd(arr, n);

    printf("Modified array: ");
    printArray(arr, n);
     return 0;
}