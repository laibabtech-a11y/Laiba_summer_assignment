#include <stdio.h>

// Function to find the nth Fibonacci number
unsigned long long get_nth_fibonacci(int n) {
    if (n < 0) {
        return 0; // Handles invalid negative input
    }
    if (n == 0) return 0;
    if (n == 1) return 1;

    unsigned long long prev2 = 0; // Represents F(i-2)
    unsigned long long prev1 = 1; // Represents F(i-1)
    unsigned long long current = 0; // Represents F(i)

    for (int i = 2; i <= n; i++) {
        current = prev1 + prev2;
        prev2 = prev1;
        prev1 = current;
    }

    return current;
}int main() {
    int n;

    printf("Enter the value of n (0-indexed): ");
    if (scanf("%d", &n) != 1) {
        printf("Invalid input.\n");
        return 1;
    }

    unsigned long long result = get_nth_fibonacci(n);
    printf("The %dth Fibonacci term is: %llu\n", n, result);

    return 0;
}