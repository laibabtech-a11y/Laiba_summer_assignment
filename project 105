#include <stdio.h>
#include <stdbool.h>

// Global constant credentials and state
#define DEFAULT_PIN 1234
#define MAX_ATTEMPTS 3

// Function prototypes
void display_menu(void);
void check_balance(double balance);
double deposit_money(double balance);
double withdraw_money(double balance);
bool authenticate_user(void);

int main(void) {
    double current_balance = 5000.00; // Starting account balance
    int choice;
    bool is_running = true;

    printf("=== WELCOME TO THE SIMULATED ATM SYSTEM ===\n");

    // Authenticate user before allowing account access
    if (!authenticate_user()) {
        printf("\nToo many incorrect attempts. Your card has been blocked.\n");
        printf("Please contact customer support. Exiting...\n");
        return 0;
    }

        
 // Main transaction loop
    while (is_running) {
        display_menu();
        printf("Select an option (1-4): ");
        
        if (scanf("%d", &choice) != 1) {
            printf("Invalid input type. Please enter numbers only.\n");
            while (getchar() != '\n'); // Clear input buffer
            continue;
        }

        switch (choice) {
            case 1:
                check_balance(current_balance);
                break;
            case 2:
                current_balance = deposit_money(current_balance);
                break;
                 case 3:
                current_balance = withdraw_money(current_balance);
                break;
            case 4:
                printf("\nThank you for using our ATM services. Goodbye!\n");
                is_running = false;
                break;
            default:
                printf("\nInvalid selection. Please choose a valid option.\n");
        }
    }

    return 0;
}

// Function to handle PIN authentication
bool authenticate_user(void) {
    int entered_pin;
    int attempts = 0;

    while (attempts < MAX_ATTEMPTS) {
        printf("Enter your 4-digit PIN: ");
        if (scanf("%d", &entered_pin) != 1) {
            while (getchar() != '\n'); // Clear buffer on invalid character input
        }

        if (entered_pin == DEFAULT_PIN) {
            return true;
        }

        attempts++;
        printf("Incorrect PIN. Attempts remaining: %d\n\n", MAX_ATTEMPTS - attempts);
    }
    return false;
}

// Function to print the selection panel
void display_menu(void) {
      printf("\n-----------------------------\n");
    printf("          ATM MENU           \n");
    printf("-----------------------------\n");
    printf("1. Check Balance\n");
    printf("2. Deposit Cash\n");
    printf("3. Withdraw Cash\n");
    printf("4. Exit\n");
    printf("-----------------------------\n");
}

// Function to display the available funds
void check_balance(double balance) {
    printf("\nYour current available balance is: $%.2f\n", balance);
}

// Function to process account funding
double deposit_money(double balance) {
    double deposit_amount;
       printf("\nEnter the amount to deposit: $");
    if (scanf("%lf", &deposit_amount) != 1 || deposit_amount <= 0) {
        printf("Invalid amount. Transaction canceled.\n");
        while (getchar() != '\n'); 
        return balance;
    }

    balance += deposit_amount;
    printf("Successfully deposited $%.2f. New Balance: $%.2f\n", deposit_amount, balance);
    return balance;
}

