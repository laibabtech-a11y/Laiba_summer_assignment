#include <stdio.h>
#include <string.h>

// Function to find the first repeating character
char findFirstRepeating(char *str) {
    // Array to store counts of 256 ASCII characters, initialized to 0
    int count[256] = {0};

    // Traverse the string from left to right
    for (int i = 0; str[i] != '\0'; i++) {
        unsigned char ch = str[i];
        
        // Increment the character count
        count[ch]++;

        // If the character has been seen before, it's our first repeating character
        if (count[ch] > 1) {
            return str[i];
        }
    }
 // Return null character if no character repeats
    return '\0';
}

int main() {
    char str[] = "programming";
    
    char result = findFirstRepeating(str);
    
    if (result != '\0') {
        printf("The first repeating character is: %c\n", result);
    } else {
        printf("No repeating characters found.\n");
    }
    
    return 0;
}