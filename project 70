#include <stdio.h>

// Function to check if an element is already present in an array
int isDuplicate(int arr[], int size, int element) {
    for (int i = 0; i < size; i++) {
        if (arr[i] == element) {
            return 1; // Element found (it's a duplicate)
        }
    }
    return 0; // Element not found
}

int main() {
    // Define two example arrays
    int arr1[] = {4, 1, 9, 4, 7, 2, 5};
    int arr2[] = {2, 7, 4, 8, 4, 12, 1};
    
    // Calculate the size of both arrays
    int size1 = sizeof(arr1) / sizeof(arr1[0]);
    int size2 = sizeof(arr2) / sizeof(arr2[0]);
      // Array to temporarily store common elements to avoid duplicate printing
    int common[100]; 
    int commonCount = 0;

    printf("Array 1: ");
    for (int i = 0; i < size1; i++) printf("%d ", arr1[i]);
    printf("\n");

    printf("Array 2: ");
    for (int i = 0; i < size2; i++) printf("%d ", arr2[i]);
    printf("\n\n");

    // Nested loop to find common elements
    for (int i = 0; i < size1; i++) {
        for (int j = 0; j < size2; j++) {
            // Check if elements match
            if (arr1[i] == arr2[j]) {
                 {
                // Check if we have already recorded this common element
                if (!isDuplicate(common, commonCount, arr1[i])) {
                    common[commonCount] = arr1[i];
                    commonCount++;
                }
                break; // Break inner loop once a match is found for arr1[i]
            }
        }
    }

    // Output the results
    if (commonCount == 0) {
        printf("No common elements found.\n");
    } else {
        printf("Common elements are: ");
        for (int i = 0; i < commonCount; i++) {
            printf("%d ", common[i]);
        }
        printf("\n");
    }
        return 0;
}